# Example Fly.io config for self-hosting afair. Copy to fly.toml, set your own
# app name + region, and `fly deploy`. See docs/self-hosting.md.
#
# afair is single-tenant by design (Invariant I8): one machine, one volume, one
# user. This config reflects that — a single always-on machine with a single
# persistent disk. Do not scale it horizontally; the substrate is local state.

app = "your-afair-app"        # set your own app name
primary_region = "fra"        # pick a region near you; fra = EU

[build]
  dockerfile = "Dockerfile"

[env]
  ENVIRONMENT = "fly"         # turns on the prod requirements (auth + vault key)
  LOG_LEVEL = "INFO"
  VAULT_DIR = "/data/vault"   # the vault lives on the mounted volume
  MCP_HOST = "0.0.0.0"
  MCP_PORT = "8080"
  EXTRACTOR_MODEL = "anthropic/claude-haiku-4-5"

# Persistent volume — your vault lives here, forever. Create it once:
#   fly volumes create vault --region <your-region> --size 1
[mounts]
  source = "vault"
  destination = "/data"

[deploy]
  # `immediate`: stop the machine, swap the image, restart. Brief downtime
  # (~10-30s) per deploy, but the single volume stays mounted on the same
  # machine, so there is no fork/race/corruption from a second writer.
  strategy = "immediate"
  wait_timeout = "5m"

[http_service]
  internal_port = 8080
  force_https = true
  # Keep the machine warm — the substrate is local state, so a cold start
  # hurts latency. min_machines_running = 1 keeps it always on.
  auto_stop_machines = "off"
  auto_start_machines = true
  min_machines_running = 1

  [http_service.concurrency]
    type = "requests"
    hard_limit = 100
    soft_limit = 50

  [[http_service.checks]]
    grace_period = "10s"
    interval = "30s"
    timeout = "5s"
    method = "GET"
    path = "/health"

[[vm]]
  size = "shared-cpu-1x"
  memory_mb = 1024            # headroom for concurrent LLM + embedding calls

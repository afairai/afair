# Copy to .env for local dev. Real values for prod live in Fly secrets +
# a secure off-repo backup. Every variable the server reads is listed here.
#
# A local single-user self-host needs only the first six sections. The
# "Hosted / multi-user deployment" section at the bottom is for the managed
# afair.ai setup (OAuth client logins, per-user provisioning, async export);
# a personal self-host can ignore all of it.

# ── Runtime
ENVIRONMENT=local                  # local | fly  (fly turns on the prod-only requirements below)
LOG_LEVEL=INFO                     # DEBUG | INFO | WARN | ERROR

# ── Substrate
# Local default: ~/vault. On Fly the persistent volume is mounted at /data/vault.
VAULT_DIR=~/vault
# Text payloads larger than this (bytes) spill to the filesystem object store;
# smaller stays inline in the SQLite row. Binary content always spills.
INLINE_TEXT_MAX_BYTES=65536

# ── MCP server
MCP_HOST=127.0.0.1                 # 0.0.0.0 on Fly
MCP_PORT=8765

# ── LLM provider (Invariant I5 — vendor-neutral via litellm)
# Format: "<provider>/<model>". Any litellm-supported model works.
# Examples: anthropic/claude-haiku-4-5, openai/gpt-4o-mini,
#           gemini/gemini-2.5-flash, ollama/llama3.3 (fully local)
EXTRACTOR_MODEL=anthropic/claude-haiku-4-5
# Image extraction model. Must be vision-capable.
VISION_MODEL=anthropic/claude-haiku-4-5
# Audio transcription model. litellm shape: openai/whisper-1,
# deepgram/nova-3, groq/whisper-large-v3.
TRANSCRIPTION_MODEL=openai/whisper-1

# Provide whichever key matches the models you selected above. Multiple may
# be set: the extractor LLM and the embedding model can use different
# providers (for example Anthropic for extraction, Voyage for embeddings).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Voyage AI = Anthropic's recommended embedding provider (they don't ship
# native embeddings). Required only if EMBEDDING_MODEL starts with voyage/.
VOYAGE_API_KEY=

# ── Embeddings (semantic recall via sqlite-vec)
# Tested provider/dimension combinations:
#   openai/text-embedding-3-small  -> EMBEDDING_DIM=1536  (default, cheapest)
#   openai/text-embedding-3-large  -> EMBEDDING_DIM=3072
#   voyage/voyage-3                -> EMBEDDING_DIM=1024
#   voyage/voyage-3-lite           -> EMBEDDING_DIM=512
#   gemini/embedding-001           -> EMBEDDING_DIM=768
#   cohere/embed-english-v3.0      -> EMBEDDING_DIM=1024
# EMBEDDING_DIM must match the model. The events_vec table is created at boot
# with this dim, and changing it requires re-embedding the whole vault.
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
# Set false to fall back to FTS-only recall (useful for local dev without an
# embedding-provider key).
SEMANTIC_RECALL_ENABLED=true

# ── Cold-path workers (background extraction, entity graph, tuning)
# When true (default) the scheduler runs the salience, mode-switcher,
# canonicalizer, consolidator, and tuner workers on their intervals. Set
# false for local dev if you don't want background LLM calls running.
COLD_PATH_ENABLED=true
# Recent-context window (event count) the surprise score compares against.
SURPRISE_CONTEXT_WINDOW=20

# ── Authentication (required when ENVIRONMENT=fly)
# Static bearer token. Optional locally (loopback binding contains the risk),
# REQUIRED on Fly or the substrate would be world-readable and world-writable.
# Every MCP client then sends: Authorization: Bearer <token>
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
AFAIR_AUTH_TOKEN=

# ── Vault encryption (required when ENVIRONMENT=fly)
# When set, the SQLite DB is opened via SQLCipher (whole-file AES-256) and
# blobs are written with AES-256-GCM. When unset, the substrate runs in
# plaintext mode (fine for local dev). Min 32 bytes. Sub-keys are derived
# via HKDF. Losing this key after a vault has been written under it = the
# data is gone. Persist it in a secure off-repo backup AND the platform secret
# store, never only one place.
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
AFAIR_VAULT_KEY=

# =========================================================================
# Hosted / multi-user deployment (optional for self-host)
# Needed only for the managed afair.ai setup: OAuth client logins
# (Claude.ai requires OAuth), per-user provisioning, and async vault export.
# A single-user self-host can leave this whole block empty.
# =========================================================================

# OAuth issuer URL: the `iss` claim on minted JWTs and the issuer in the
# OAuth discovery metadata. REQUIRED when ENVIRONMENT=fly (even for a
# static-bearer-only deployment). Local dev derives http://<host>:<port>.
OAUTH_ISSUER=

# Identity backend: "hub" (federated GitHub OAuth via afair.ai, default) or
# "github" (legacy direct GitHub OAuth, kept for fallback).
IDENTITY_BACKEND=hub
# Federated identity hub (used when IDENTITY_BACKEND=hub).
IDENTITY_HUB_URL=https://afair.ai
IDENTITY_HUB_SECRET=
# Comma-separated allowlist of authenticated identities. Single-tenant per
# I8: typically one GitHub username / Clerk userId per instance.
IDENTITY_ALLOWLIST=

# OAuth server JWT signing secret (HS256).
AFAIR_JWT_SECRET=
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# Legacy direct GitHub OAuth credentials (only when IDENTITY_BACKEND=github).
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Scoped bearer accepted only on /internal/signup (the afair-web landing page
# writes early-access signups; it never gets the full vault bearer).
AFAIR_SIGNUP_TOKEN=
# Scoped bearer accepted only on /internal/export (whole-vault JSONL stream).
AFAIR_EXPORT_TOKEN=
# Shared bearer for the export-ready callback to afair-web (emails the user
# their download link when an async export finishes). Optional: without it the
# job still completes and the dashboard poll surfaces it.
EXPORT_READY_CALLBACK_SECRET=
# How long a generated export artifact + its download link live before
# auto-purge (hours). 72h is the GDPR-export norm.
EXPORT_RETENTION_HOURS=72

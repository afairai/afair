# Copy to .env for local dev. Real values for prod live in Fly secrets + .env.secrets.backup.

# ── Runtime
ENVIRONMENT=local                  # local | fly
LOG_LEVEL=INFO                     # DEBUG | INFO | WARN | ERROR

# ── Substrate
# Local default: ~/vault — on Fly the persistent volume is mounted at /data/vault
VAULT_DIR=~/vault

# ── MCP server
MCP_HOST=127.0.0.1                 # 0.0.0.0 on Fly
MCP_PORT=8765

# ── LLM provider (Invariant I5 — vendor-neutral via litellm)
# Format: "<provider>/<model>". Any litellm-supported model works.
# Examples:
#   anthropic/claude-haiku-4-5
#   openai/gpt-4o-mini
#   gemini/gemini-2.5-flash
#   ollama/llama3.3            (fully local)
EXTRACTOR_MODEL=anthropic/claude-haiku-4-5

# Provide whichever key matches the selected model. Multiple may be set —
# embedding and LLM can come from different providers (e.g., Anthropic for
# the extractor LLM + Voyage AI for embeddings).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Voyage AI = Anthropic's recommended embedding provider (they don't ship
# native embeddings). Required only if EMBEDDING_MODEL starts with voyage/.
VOYAGE_API_KEY=

# ── Embeddings (Phase 1 — semantic recall via sqlite-vec)
# Tested provider/dimension combinations:
#   openai/text-embedding-3-small  → EMBEDDING_DIM=1536  (default, cheapest)
#   openai/text-embedding-3-large  → EMBEDDING_DIM=3072
#   voyage/voyage-3                → EMBEDDING_DIM=1024
#   voyage/voyage-3-lite           → EMBEDDING_DIM=512
#   gemini/embedding-001           → EMBEDDING_DIM=768
#   cohere/embed-english-v3.0      → EMBEDDING_DIM=1024
# EMBEDDING_DIM must match the model — events_vec table is created at boot
# with this dim and changing it requires re-embedding the whole vault.
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# ── Authentication (Phase 0: bearer token)
# Required when ENVIRONMENT=fly; optional locally (loopback binding contains
# the risk). Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Then every MCP client must send: Authorization: Bearer <token>
NEVERFORGET_AUTH_TOKEN=

# Copy to .env for local dev. Real values for prod live in your platform's
# secret store + a secure off-repo backup. Every variable is listed here,
# grouped by who needs it:
#
#   Core (the sections above the dividers) — a self-host running CLI/desktop
#     clients (Claude Code, Codex, Cursor) needs only these; a local run
#     needs even less.
#   Section 7 — web-client logins (Claude.ai, ChatGPT). Optional, only to
#     serve browser clients from a public deployment.
#   Section 8 — managed afair.ai fleet only. A self-host ignores it.

# ── Runtime
# ENVIRONMENT: "fly" is the label for any public/hosted deployment (not just
# Fly.io); it turns on the production requirements flagged below.
ENVIRONMENT=local                  # local | fly
LOG_LEVEL=INFO                     # DEBUG | INFO | WARN | ERROR

# ── Substrate
# Local default: ~/vault. On Fly the persistent volume is mounted at /data/vault.
VAULT_DIR=~/vault
# Text payloads larger than this (bytes) spill to the filesystem object store;
# smaller stays inline in the SQLite row. Binary content always spills.
INLINE_TEXT_MAX_BYTES=65536

# ── MCP server
MCP_HOST=127.0.0.1                 # 0.0.0.0 on Fly
MCP_PORT=8765

# ── LLM provider (Invariant I5 — vendor-neutral via litellm)
# Format: "<provider>/<model>". Any litellm-supported model works.
# Examples: anthropic/claude-haiku-4-5, openai/gpt-4o-mini,
#           gemini/gemini-2.5-flash, ollama/llama3.3 (fully local)
EXTRACTOR_MODEL=anthropic/claude-haiku-4-5
# Image extraction model. Must be vision-capable.
VISION_MODEL=anthropic/claude-haiku-4-5
# Audio transcription model. litellm shape: openai/whisper-1,
# deepgram/nova-3, groq/whisper-large-v3.
TRANSCRIPTION_MODEL=openai/whisper-1

# ── Per-agent model overrides (all optional; unset = EXTRACTOR_MODEL)
# Heterogeneous models per agent: this is the "premium model for the harder
# agents" knob. Point reasoning-heavy workers (consolidation, conflict
# resolution) at a stronger model while the routine ones stay on the cheap
# default. Same "<provider>/<model>" litellm format.
# CANONICALIZER_MODEL=
# ENTITY_DEDUP_MODEL=
# CONFLICT_RESOLVER_MODEL=
# CONSOLIDATOR_MODEL=
# ENTITY_ARTICLES_MODEL=
# LIVING_SYNTHESES_MODEL=
# TEMPORAL_MODEL=
# Schema-Evolver (ontology-revision proposals; ADR-0003). VISION §6.5
# recommends a Sonnet-class model here once proposals matter.
# SCHEMA_EVOLVER_MODEL=
# Judge panel for the self-improvement tuner: comma-separated litellm models.
# Unset keeps the built-in cross-vendor default (Anthropic + OpenAI + Gemini).
# JUDGE_PANEL=anthropic/claude-sonnet-4-5,openai/gpt-5,gemini/gemini-2.5-pro

# Provide whichever key matches the models you selected above. Multiple may
# be set: the extractor LLM and the embedding model can use different
# providers (for example Anthropic for extraction, Voyage for embeddings).
# One key is enough: point every *_MODEL at one provider (e.g. all openai/* on
# a single OPENAI_API_KEY covers text, vision, embeddings, audio). Or run fully
# local and key-less with ollama/* models. See docs/self-hosting.md
# ("How many API keys do I need?"). Defaults use two (Anthropic + OpenAI).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Voyage AI = Anthropic's recommended embedding provider (they don't ship
# native embeddings). Required only if EMBEDDING_MODEL starts with voyage/.
VOYAGE_API_KEY=

# ── Embeddings (semantic recall via sqlite-vec)
# Tested provider/dimension combinations:
#   openai/text-embedding-3-small  -> EMBEDDING_DIM=1536  (default, cheapest)
#   openai/text-embedding-3-large  -> EMBEDDING_DIM=3072
#   voyage/voyage-3                -> EMBEDDING_DIM=1024
#   voyage/voyage-3-lite           -> EMBEDDING_DIM=512
#   gemini/embedding-001           -> EMBEDDING_DIM=768
#   cohere/embed-english-v3.0      -> EMBEDDING_DIM=1024
#   fastembed/BAAI/bge-small-en-v1.5 -> EMBEDDING_DIM=384  (local ONNX, no key)
# EMBEDDING_DIM must match the model. The events_vec table is created at boot
# with this dim, and changing it requires re-embedding the whole vault.
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
# Set false to fall back to FTS-only recall (useful for local dev without an
# embedding-provider key).
SEMANTIC_RECALL_ENABLED=true

# ── Fully-local preset (no external provider, no key; see docs/self-hosting.md
#    "Run it fully local"). Uncomment to replace the four lines above. Needs a
#    running Ollama (`ollama serve` + `ollama pull qwen2.5:7b`); the extractor
#    LLM wants ~8-16 GB RAM. Audio has no local route yet, so skip it.
# EXTRACTOR_MODEL=ollama/qwen2.5:7b
# VISION_MODEL=ollama/llama3.2-vision:11b
# EMBEDDING_MODEL=fastembed/BAAI/bge-small-en-v1.5
# EMBEDDING_DIM=384

# ── GitHub Copilot preset (use your Copilot subscription, no API key; see
#    docs/self-hosting.md "Use your GitHub Copilot subscription"). litellm
#    self-authenticates via GitHub's device flow on first run: afair prints a
#    github.com/login/device URL + code once, then caches the token.
#    Copilot serves CHAT ONLY — no embedding, vision, or transcription models.
#    So only EXTRACTOR_MODEL uses it; embeddings go local via fastembed, and
#    images/audio need a real provider key (or just skip those memory types).
# EXTRACTOR_MODEL=github_copilot/gpt-4.1
# EMBEDDING_MODEL=fastembed/BAAI/bge-small-en-v1.5
# EMBEDDING_DIM=384
# VISION_MODEL / TRANSCRIPTION_MODEL: not available on Copilot — leave the
# defaults (need an API key) or point them at a local model.

# ── Cold-path workers (background extraction, entity graph, tuning)
# When true (default) the scheduler runs the salience, mode-switcher,
# canonicalizer, consolidator, and tuner workers on their intervals. Set
# false for local dev if you don't want background LLM calls running.
COLD_PATH_ENABLED=true
# Recent-context window (event count) the surprise score compares against.
SURPRISE_CONTEXT_WINDOW=20

# ── Authentication (required when ENVIRONMENT=fly)
# Static bearer token. Optional locally (loopback binding contains the risk),
# REQUIRED on Fly or the substrate would be world-readable and world-writable.
# Every MCP client then sends: Authorization: Bearer <token>
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
AFAIR_AUTH_TOKEN=

# ── Vault encryption (required when ENVIRONMENT=fly)
# When set, the SQLite DB is opened via SQLCipher (whole-file AES-256) and
# blobs are written with AES-256-GCM. When unset, the substrate runs in
# plaintext mode (fine for local dev). Min 32 bytes. Sub-keys are derived
# via HKDF. Losing this key after a vault has been written under it = the
# data is gone. Persist it in a secure off-repo backup AND the platform secret
# store, never only one place.
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
AFAIR_VAULT_KEY=

# =========================================================================
# 7. Web-client logins (Claude.ai, ChatGPT) — OPTIONAL
# =========================================================================
# CLI / desktop clients (Claude Code, Codex, Cursor, Windsurf) authenticate
# with the static AFAIR_AUTH_TOKEN above and need NONE of this section.
#
# Web clients (Claude.ai, ChatGPT) cannot send a bearer token or reach
# localhost: they need a public HTTPS URL and a browser OAuth flow. To serve
# them from a self-hosted instance, run a public deployment and register your
# own free GitHub OAuth app (https://github.com/settings/developers). Full
# walkthrough: docs/self-hosting.md.

# OAuth issuer URL: the `iss` claim on minted JWTs and the issuer in the
# OAuth discovery metadata. REQUIRED when ENVIRONMENT=fly (even for a
# static-bearer-only deployment). Local dev derives http://<host>:<port>.
OAUTH_ISSUER=

# OAuth server JWT signing secret (HS256).
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(32))'
AFAIR_JWT_SECRET=
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# Who may log in. Comma-separated, single-tenant per I8: typically one GitHub
# username (github backend) or Clerk userId (hub backend).
IDENTITY_ALLOWLIST=

# Identity backend: how a web-client login proves who you are.
#   "github" = your own GitHub OAuth app — the self-host path. Set the two
#              credentials below; no afair.ai involvement.
#   "hub"    = federated through the managed afair.ai control plane. Hosted
#              fleet only; a self-host cannot use it.
IDENTITY_BACKEND=github
# GitHub OAuth app credentials (used when IDENTITY_BACKEND=github).
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# =========================================================================
# 8. Managed afair.ai fleet only — IGNORE for self-host
# =========================================================================
# These wire a per-user machine to the afair.ai control plane: the federated
# identity hub, early-access signup intake, and async vault export. A
# self-hosted instance leaves this whole block empty.

# Federated identity hub (used when IDENTITY_BACKEND=hub).
IDENTITY_HUB_URL=https://afair.ai
IDENTITY_HUB_SECRET=

# Scoped bearer accepted only on /internal/signup (the afair-web landing page
# writes early-access signups; it never gets the full vault bearer).
AFAIR_SIGNUP_TOKEN=
# Scoped bearer accepted only on /internal/export (whole-vault JSONL stream).
AFAIR_EXPORT_TOKEN=
# Shared bearer for the export-ready callback to afair-web (emails the user
# their download link when an async export finishes). Optional: without it the
# job still completes and the dashboard poll surfaces it.
EXPORT_READY_CALLBACK_SECRET=
# How long a generated export artifact + its download link live before
# auto-purge (hours). 72h is the GDPR-export norm.
EXPORT_RETENTION_HOURS=72
